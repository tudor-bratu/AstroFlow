---
import Base from '../layouts/Base.astro';
---

<Base title="Sandbox — Client-First Astro">

  <!-- ============================================================
    HOW TO USE THIS SANDBOX:
    1. Each section below is a self-contained component
    2. Name sections: section_[identifier]
    3. Add section-style-* combo class for backgrounds
    4. Add section-spacing-* combo class for vertical spacing
    5. Always wrap content in: padding-global > container-[size]
    6. Use utility classes for typography and spacing
    7. Use custom classes (with _) for component-specific styles
    ============================================================ -->


  <!-- ═══════════════════════════════════════════════
    SECTION: HERO
    Custom class: section_hero
    Combo classes: section-style-light section-spacing-huge
  ═══════════════════════════════════════════════ -->
  <section class="section_hero section-style-light section-spacing-huge">
    <div class="padding-global">
      <div class="container-large">
        <div class="hero_content-wrapper">
          <!-- Label -->
          <p class="hero_label text-style-label text-color-brand margin-bottom-small">
            Your tagline goes here
          </p>

          <!-- Heading — no class needed if you want default h1 styles -->
          <h1 class="hero_heading margin-bottom-medium">
            Build faster with<br />
            <span class="hero_heading-accent">Client-First</span>
          </h1>

          <!-- Subtext -->
          <p class="hero_subtext text-size-xlarge text-color-secondary max-width-medium margin-bottom-large">
            A production-ready Astro starter with Finsweet's Client-First v2 CSS system.
            Every section is isolated, namespaced, and respects the brand.
          </p>

          <!-- CTA buttons -->
          <div class="hero_button-group">
            <a href="/styleguide" class="button-primary is-large">View Styleguide</a>
            <a href="#sandbox-section" class="button-secondary is-large">Explore →</a>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════
    SECTION: FEATURE CARDS
    Custom class: section_features
    Combo classes: section-style-subtle section-spacing-large
  ═══════════════════════════════════════════════ -->
  <section class="section_features section-style-subtle section-spacing-large" id="sandbox-section">
    <div class="padding-global">
      <div class="container-large">

        <!-- Section header -->
        <div class="features_header-wrapper margin-bottom-xlarge">
          <p class="text-style-label text-color-brand margin-bottom-small">Features</p>
          <h2 class="heading-style-h2 max-width-medium">
            Everything you need to build
          </h2>
          <p class="text-color-secondary text-size-large max-width-medium margin-top-small">
            A complete system from layout to typography, ready for your brand.
          </p>
        </div>

        <!-- Feature grid -->
        <div class="features_grid">
          <div class="feature-card_component">
            <div class="feature-card_icon-wrapper">
              <svg class="icon-large" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
              </svg>
            </div>
            <h3 class="feature-card_heading heading-style-h5 margin-bottom-small">Client-First v2</h3>
            <p class="feature-card_text text-color-secondary">
              Full Finsweet naming convention — utility classes with dashes, custom classes with underscores.
            </p>
          </div>

          <div class="feature-card_component">
            <div class="feature-card_icon-wrapper">
              <svg class="icon-large" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
              </svg>
            </div>
            <h3 class="feature-card_heading heading-style-h5 margin-bottom-small">Isolated Sections</h3>
            <p class="feature-card_text text-color-secondary">
              Every section is namespaced with <code>section_[name]</code>. Build them independently, compose freely.
            </p>
          </div>

          <div class="feature-card_component">
            <div class="feature-card_icon-wrapper">
              <svg class="icon-large" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
              </svg>
            </div>
            <h3 class="feature-card_heading heading-style-h5 margin-bottom-small">Brand Ready</h3>
            <p class="feature-card_text text-color-secondary">
              One CSS variable file controls all brand colors. Change <code>--color--brand</code> and the whole site updates.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════
    SECTION: DARK CTA
    Custom class: section_cta
    Combo classes: section-style-dark section-spacing-large
  ═══════════════════════════════════════════════ -->
  <section class="section_cta section-style-dark section-spacing-large">
    <div class="padding-global">
      <div class="container-medium">
        <div class="cta_content-wrapper">
          <p class="text-style-label text-color-brand margin-bottom-small">Get started</p>
          <h2 class="heading-style-h2 text-color-inverted margin-bottom-medium">
            Ready to build something great?
          </h2>
          <p class="text-color-muted text-size-large margin-bottom-large max-width-medium">
            This starter is your foundation. Clone it, customize the brand colors, and start building sections.
          </p>
          <div class="cta_button-group">
            <a href="/styleguide" class="button-primary is-large">See the Styleguide</a>
            <a href="#" class="button-neutral is-large">Read the Docs</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  /* ===== hero section ===== */
  .hero_content-wrapper {
    max-width: 48rem;
  }

  .hero_label {
    display: inline-block;
  }

  .hero_heading {
    letter-spacing: -0.03em;
  }

  .hero_heading-accent {
    color: var(--color--brand);
  }

  .hero_button-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing--small);
    align-items: center;
  }

  /* ===== features section ===== */
  .features_header-wrapper {
    max-width: 42rem;
  }

  .features_grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing--large);
  }

  @media (max-width: 767px) {
    .features_grid { grid-template-columns: 1fr; }
  }

  /* ===== feature card ===== */
  .feature-card_component {
    padding: var(--spacing--large);
    background-color: var(--color--bg-primary);
    border: 1px solid var(--color--border);
    border-radius: var(--radius-large);
  }

  .feature-card_icon-wrapper {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-medium);
    background-color: var(--color--brand-light);
    color: var(--color--brand);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--spacing--medium);
  }

  /* ===== cta section ===== */
  .cta_content-wrapper {
    text-align: center;
  }

  .cta_button-group {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing--small);
    justify-content: center;
  }

  code {
    font-family: var(--font-mono);
    font-size: 0.85em;
    background-color: var(--color--neutral-100);
    padding: 0.125rem 0.375rem;
    border-radius: var(--radius-small);
    color: var(--color--brand);
  }
</style>
